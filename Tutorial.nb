Cell[BoxData[
 DynamicModuleBox[{CrittografiaArcaica`Private`seed$$ = 42, 
  CrittografiaArcaica`Private`messaggioCifrato$$ = "", 
  CrittografiaArcaica`Private`shiftSegreto$$ = 0, 
  CrittografiaArcaica`Private`messaggioChiaro$$ = "", 
  CrittografiaArcaica`Private`rispostaUtente$$ = "", 
  CrittografiaArcaica`Private`tentativi$$ = 0, 
  CrittografiaArcaica`Private`feedbackMsg$$ = "", 
  CrittografiaArcaica`Private`soluzioneVisibile$$ = False, 
  CrittografiaArcaica`Private`suggerimentoStep$$ = 0, 
  CrittografiaArcaica`Private`esercizioGenerato$$ = False}, 
  PanelBox[
   TagBox[GridBox[{
      {
       StyleBox["\<\"Esercizi \[LongDash] Cifrario di Cesare\"\>",
        StripOnInput->False,
        LineColor->RGBColor[0.2, 0.4, 0.7],
        FrontFaceColor->RGBColor[0.2, 0.4, 0.7],
        BackFaceColor->RGBColor[0.2, 0.4, 0.7],
        GraphicsColor->RGBColor[0.2, 0.4, 0.7],
        FontSize->18,
        FontWeight->Bold,
        FontColor->RGBColor[0.2, 0.4, 0.7]]},
      {
       StyleBox["\<\"Ti viene dato un testo cifrato: trova il testo originale \
in chiaro!\"\>",
        StripOnInput->False,
        LineColor->GrayLevel[0.5],
        FrontFaceColor->GrayLevel[0.5],
        BackFaceColor->GrayLevel[0.5],
        GraphicsColor->GrayLevel[0.5],
        FontSize->12,
        FontSlant->Italic,
        FontColor->GrayLevel[0.5]]},
      {
       TemplateBox[{8},
        "Spacer1"]},
      {
       TemplateBox[{
         StyleBox["\"Seed: \"", 13, Bold, StripOnInput -> False], 
         InputFieldBox[
          Dynamic[CrittografiaArcaica`Private`seed$$], Number, 
          FieldSize -> {8, 1}, FieldHint -> "es. 42"], 
         TemplateBox[{8}, "Spacer1"], 
         ButtonBox[
          StyleBox["\"Genera Esercizio\"", 13, Bold, 
           GrayLevel[1], StripOnInput -> False], ButtonFunction :> 
          Module[{CrittografiaArcaica`Private`ris$}, 
            CrittografiaArcaica`Private`ris$ = 
             CrittografiaArcaica`Private`generaEsercizioConSeedCesare[
              CrittografiaArcaica`Private`seed$$]; 
            CrittografiaArcaica`Private`messaggioCifrato$$ = 
             Part[CrittografiaArcaica`Private`ris$, 1]; 
            CrittografiaArcaica`Private`shiftSegreto$$ = 
             Part[CrittografiaArcaica`Private`ris$, 2]; 
            CrittografiaArcaica`Private`messaggioChiaro$$ = 
             Part[CrittografiaArcaica`Private`ris$, 3]; 
            CrittografiaArcaica`Private`rispostaUtente$$ = ""; 
            CrittografiaArcaica`Private`tentativi$$ = 0; 
            CrittografiaArcaica`Private`feedbackMsg$$ = ""; 
            CrittografiaArcaica`Private`soluzioneVisibile$$ = False; 
            CrittografiaArcaica`Private`suggerimentoStep$$ = 0; 
            CrittografiaArcaica`Private`esercizioGenerato$$ = True; Null], 
          Background -> RGBColor[0.15, 0.5, 0.8], ImageSize -> {160, 35}, 
          Appearance -> Automatic, Evaluator -> Automatic, Method -> 
          "Preemptive"]},
        "RowDefault"]},
      {
       TemplateBox[{8},
        "Spacer1"]},
      {
       DynamicBox[ToBoxes[
         If[CrittografiaArcaica`Private`esercizioGenerato$$, 
          Framed[
           Column[{
             Style["Testo cifrato da decifrare:", 12, Bold, 
              RGBColor[0.7, 0.3, 0.1]], 
             Style[
             CrittografiaArcaica`Private`messaggioCifrato$$, 15, Bold, 
              Black]}], Background -> RGBColor[1., 0.95, 0.88], 
           RoundingRadius -> 5, FrameStyle -> RGBColor[0.7, 0.3, 0.1], 
           FrameMargins -> 8], 
