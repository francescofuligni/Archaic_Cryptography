               StringLength[CrittografiaArcaica`Private`messaggioChiaro$$]]] <> 
            "'.", 12, Italic, 
            RGBColor[0.5, 0.4, 0.]], Background -> RGBColor[1., 0.97, 0.85], 
           RoundingRadius -> 5, FrameMargins -> 8]], StandardForm],
