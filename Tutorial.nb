          If[CrittografiaArcaica`Private`esercizioGenerato$$, 
            Increment[CrittografiaArcaica`Private`tentativi$$]; If[ToUpperCase[
                StringReplace[
                 StringTrim[CrittografiaArcaica`Private`rispostaUtente$$], 
                 " " -> ""]] === 
              StringReplace[
               CrittografiaArcaica`Private`messaggioChiaro$$, " " -> ""], 
              CrittografiaArcaica`Private`feedbackMsg$$ = 
              "\[Checkmark] Corretto! Hai impiegato " <> 
               ToString[CrittografiaArcaica`Private`tentativi$$] <> 
               If[CrittografiaArcaica`Private`tentativi$$ == 1, " tentativo.",
                  " tentativi."], 
              If[
              CrittografiaArcaica`Private`tentativi$$ >= 3, 
               CrittografiaArcaica`Private`feedbackMsg$$ = 
                "\[Cross] Risposta errata. Tentativi esauriti."; 
               CrittografiaArcaica`Private`soluzioneVisibile$$ = True, 
               CrittografiaArcaica`Private`suggerimentoStep$$ = 
                CrittografiaArcaica`Private`tentativi$$; 
               CrittografiaArcaica`Private`feedbackMsg$$ = 
                "\[Cross] Non corretto \[LongDash] Tentativo " <> 
                 ToString[CrittografiaArcaica`Private`tentativi$$] <> "/3.  " <> 
                 Which[CrittografiaArcaica`Private`tentativi$$ == 1, 
                   "Suggerimento: per decifrare, sottrai lo shift invece di \
sommarlo. " <> "La prima lettera della chiave e' '" <> 
                   StringTake[CrittografiaArcaica`Private`chiaveSegreto$$, 1] <> 
                   "'.", CrittografiaArcaica`Private`tentativi$$ == 2, 
                   "Suggerimento: la chiave ha " <> ToString[
                    StringLength[
                    CrittografiaArcaica`Private`chiaveSegreto$$]] <> 
                   " lettere. Applicala al contrario, lettera per lettera.", 
                   True, ""]]]], Background -> RGBColor[0.2, 0.6, 0.3], 
          ImageSize -> {170, 35}, Appearance -> Automatic, Evaluator -> 
          Automatic, Method -> "Preemptive"], 
         TemplateBox[{8}, "Spacer1"], 
         ButtonBox[
          StyleBox["\"Pulisci Campi\"", 13, Bold, 
           GrayLevel[1], StripOnInput -> False], 
          ButtonFunction :> (CrittografiaArcaica`Private`seed$$ = 42; 
           CrittografiaArcaica`Private`messaggioCifrato$$ = ""; 
           CrittografiaArcaica`Private`chiaveSegreto$$ = ""; 
           CrittografiaArcaica`Private`messaggioChiaro$$ = ""; 
           CrittografiaArcaica`Private`rispostaUtente$$ = ""; 
           CrittografiaArcaica`Private`tentativi$$ = 0; 
           CrittografiaArcaica`Private`feedbackMsg$$ = ""; 
           CrittografiaArcaica`Private`soluzioneVisibile$$ = False; 
           CrittografiaArcaica`Private`suggerimentoStep$$ = 0; 
           CrittografiaArcaica`Private`esercizioGenerato$$ = False; Null), 
          Background -> RGBColor[0.5, 0.5, 0.5], ImageSize -> {140, 35}, 
          Appearance -> Automatic, Evaluator -> Automatic, Method -> 
          "Preemptive"]},
        "RowDefault"]},
      {
       TemplateBox[{4},
        "Spacer1"]},
      {
       TemplateBox[{
         ButtonBox[
          StyleBox["\"Suggerimento\"", 13, Bold, 
           GrayLevel[1], StripOnInput -> False], ButtonFunction :> If[
            And[
            CrittografiaArcaica`Private`esercizioGenerato$$, 
             CrittografiaArcaica`Private`suggerimentoStep$$ < 3], 
            Increment[CrittografiaArcaica`Private`suggerimentoStep$$]], 
          Background -> RGBColor[0.8, 0.6, 0.1], ImageSize -> {140, 35}, 
          Appearance -> Automatic, Evaluator -> Automatic, Method -> 
          "Preemptive"], 
         TemplateBox[{8}, "Spacer1"], 
         ButtonBox[
          StyleBox["\"Mostra Soluzione\"", 13, Bold, 
           GrayLevel[1], StripOnInput -> False], ButtonFunction :> 
          If[
           CrittografiaArcaica`Private`esercizioGenerato$$, 
            CrittografiaArcaica`Private`soluzioneVisibile$$ = True], 
          Background -> RGBColor[0.7, 0.2, 0.2], ImageSize -> {160, 35}, 
          Appearance -> Automatic, Evaluator -> Automatic, Method -> 
          "Preemptive"]},
        "RowDefault"]},
      {
       TemplateBox[{8},
        "Spacer1"]},
      {
       DynamicBox[ToBoxes[
         If[CrittografiaArcaica`Private`feedbackMsg$$ =!= "", 
          Framed[
           Style[CrittografiaArcaica`Private`feedbackMsg$$, 12, 
