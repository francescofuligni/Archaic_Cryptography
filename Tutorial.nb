Cell[CellGroupData[{

Cell["III.3 Esercizi \[LongDash] Cifrario di Vigen\[EGrave]re", "Section",
 CellChangeTimes->{
  3.98585594222692*^9},ExpressionUUID->"f8014d85-da00-4baa-976f-564719ea235f"],

Cell["\<\
Funziona esattamente come gli esercizi sul Cifrario di Cesare, ma questa \
volta dovrai decifrare un messaggio cifrato con Vigen\[EGrave]re.

Le funzionalit\[AGrave] disponibili sono:
  \[Bullet] Genera Esercizio (con Seed riproducibile);
  \[Bullet] Verifica Risultato (3 tentativi massimi);
  \[Bullet] Suggerimento progressivo (3 livelli: tipo di cifrario \
\[RightArrow] lunghezza chiave \[RightArrow] prima lettera);
  \[Bullet] Mostra Soluzione (chiave e testo in chiaro);
  \[Bullet] Pulisci Campi (ripristina l\[CloseCurlyQuote]interfaccia).\
\>", "Text",
 CellChangeTimes->{
  3.985855949212084*^9},ExpressionUUID->"166821d6-3e9e-43e6-baec-\
18f4f3901625"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"esercizioUniversaleVigenere", "[", "]"}]], "Input",
 CellOpen->False,
 CellChangeTimes->{3.985855956389786*^9},
 CellLabel->"In[78]:=",ExpressionUUID->"177c5de9-4ab1-44cf-9077-917085a37459"],

Cell[BoxData[
 DynamicModuleBox[{CrittografiaArcaica`Private`seed$$ = 42, 
  CrittografiaArcaica`Private`messaggioCifrato$$ = "", 
  CrittografiaArcaica`Private`chiaveSegreto$$ = "", 
  CrittografiaArcaica`Private`messaggioChiaro$$ = "", 
  CrittografiaArcaica`Private`rispostaUtente$$ = "", 
  CrittografiaArcaica`Private`tentativi$$ = 0, 
  CrittografiaArcaica`Private`feedbackMsg$$ = "", 
  CrittografiaArcaica`Private`soluzioneVisibile$$ = False, 
  CrittografiaArcaica`Private`suggerimentoStep$$ = 0, 
  CrittografiaArcaica`Private`esercizioGenerato$$ = False}, 
  PanelBox[
   TagBox[GridBox[{
      {
       StyleBox["\<\"Esercizi \[LongDash] Cifrario di Vigenere\"\>",
        StripOnInput->False,
        LineColor->RGBColor[0.5, 0.2, 0.7],
        FrontFaceColor->RGBColor[0.5, 0.2, 0.7],
        BackFaceColor->RGBColor[0.5, 0.2, 0.7],
        GraphicsColor->RGBColor[0.5, 0.2, 0.7],
        FontSize->18,
        FontWeight->Bold,
        FontColor->RGBColor[0.5, 0.2, 0.7]]},
      {
       StyleBox["\<\"Ti vengono dati il testo cifrato e la chiave: trova il \
testo in chiaro!\"\>",
        StripOnInput->False,
        LineColor->GrayLevel[0.5],
        FrontFaceColor->GrayLevel[0.5],
        BackFaceColor->GrayLevel[0.5],
        GraphicsColor->GrayLevel[0.5],
        FontSize->12,
        FontSlant->Italic,
