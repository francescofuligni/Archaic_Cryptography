          CrittografiaArcaica`Private`suggerimentoStep$$ == 1, 
          Framed[
           Style[
           "\[LightBulb] Suggerimento 1: per decifrare Vigenere, per ogni \
lettera del testo cifrato si SOTTRAE (invece di sommare) lo shift della \
lettera chiave corrispondente. La prima lettera della chiave e' '" <> 
            StringTake[CrittografiaArcaica`Private`chiaveSegreto$$, 1] <> 
            "' (shift " <> ToString[Part[
                Position[CrittografiaArcaica`Private`alfabeto, 
                 ToUpperCase[
                  StringTake[
                  CrittografiaArcaica`Private`chiaveSegreto$$, 1]]], 1, 1] - 
              1] <> ").", 12, Italic, 
            RGBColor[0.5, 0.4, 0.]], Background -> RGBColor[1., 0.97, 0.85], 
           RoundingRadius -> 5, FrameMargins -> 8], 
          CrittografiaArcaica`Private`suggerimentoStep$$ == 2, 
          Framed[
           Style[
           "\[LightBulb] Suggerimento 2: la chiave '" <> 
