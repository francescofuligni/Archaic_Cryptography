Cell[CellGroupData[{

Cell["III.3 Esercizi - Cifrario di Vigen\[EGrave]re", "Section",
 CellChangeTimes->{
  3.98585594222692*^9, {3.9858758285873117`*^9, 
   3.985875829217224*^9}},ExpressionUUID->"f8014d85-da00-4baa-976f-\
564719ea235f"],

Cell["\<\
Funziona esattamente come gli esercizi sul Cifrario di Cesare, ma questa \
volta dovrai decifrare un messaggio cifrato con Vigen\[EGrave]re.\
\>", "Text",
 CellChangeTimes->{
  3.985855949212084*^9, {3.985876568771673*^9, 
   3.985876602573556*^9}},ExpressionUUID->"166821d6-3e9e-43e6-baec-\
18f4f3901625"],

Cell[CellGroupData[{

Cell["Come funziona?", "Subsection",
 CellChangeTimes->{{3.985876614516313*^9, 
  3.98587662160575*^9}},ExpressionUUID->"919a738b-719d-40e7-b318-\
3ed48484234a"],

Cell["\<\
  \[Bullet] Genera Esercizio (con Seed riproducibile);
  \[Bullet] Verifica Risultato (3 tentativi massimi);
  \[Bullet] Suggerimento progressivo (3 livelli: tipo di cifrario \
\[RightArrow] lunghezza chiave \[RightArrow] prima lettera);
  \[Bullet] Mostra Soluzione (chiave e testo in chiaro);
  \[Bullet] Pulisci Campi (ripristina l\[CloseCurlyQuote]interfaccia).\
\>", "Text",
 CellChangeTimes->{
  3.98587662511616*^9},ExpressionUUID->"490a4142-bcd6-472f-9a73-c461ee3245d9"],

